{
  "name": "momento",
  "displayName": "Momento 鐩稿唽",
  "version": "1.0.0",
  "description": "瀹夊叏銆佺瀵嗐€佹櫤鑳界殑鐓х墖绠＄悊搴旂敤 鈥?Momento",
  "author": "Momento Team",
  "homepage": "https://momento.example.com",
  "license": "MIT",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build:ios": "cd ios && xcodebuild -workspace Momento.xcworkspace -scheme Momento -configuration Release archive",
    "clean": "node scripts/clean.js all",
    "clean:android": "node scripts/clean.js android",
    "clean:ios": "node scripts/clean.js ios",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major"
  },
  "dependencies": {
    "@bam.tech/react-native-image-resizer": "^3.0.7",
    "@gorhom/bottom-sheet": "^4.6.4",
    "@nozbe/watermelondb": "^0.27.1",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "@react-native-community/netinfo": "9.4.1",
    "@react-native-ml-kit/face-detection": "^1.0.0",
    "@react-native-ml-kit/image-labeling": "^1.0.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "6.1.9",
    "@react-navigation/native-stack": "6.9.16",
    "@shopify/flash-list": "^1.7.1",
    "lucide-react-native": "^1.16.0",
    "react": "18.2.0",
    "react-native": "0.72.10",
    "react-native-amap3d": "^3.2.4",
    "react-native-biometrics": "^3.0.1",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-image-picker": "^5.6.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-maps": "^1.7.1",
    "react-native-mmkv": "^2.10.2",
    "react-native-paper": "5.11.1",
    "react-native-push-notification": "^8.1.1",
    "react-native-reanimated": "3.5.0",
    "react-native-safe-area-context": "4.5.0",
    "react-native-screens": "3.21.0",
    "react-native-share": "^9.4.1",
    "react-native-svg": "^13.14.1",
    "react-native-video": "^6.0.0-rc.1",
    "react-native-webview": "^13.6.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/runtime": "^7.24.4",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@react-native/typescript-config": "^0.85.3",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.74",
    "@types/react-test-renderer": "^18.0.7",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "metro-minify-terser": "^0.76.7",
    "metro-react-native-babel-preset": "^0.76.8",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.4.3"
  },
  "eslintConfig": {
    "extends": "@react-native",
    "rules": {
      "no-unused-vars": "warn",
      "@typescript-eslint/no-unused-vars": "warn"
    }
  },
  "react-native": {
    "hermesEnabled": true
  },
  "rnpm": {
    "assets": [
      "./assets/fonts/"
    ]
  }
}

